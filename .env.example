# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx        # publishable / anon key
SUPABASE_SERVICE_ROLE_KEY=eyJ...                        # secret! server-only, never exposed

# ── Cron / server auth ──────────────────────────────────────────────────────
CRON_SECRET=generate-a-long-random-string              # guards /api/cron/* and Vercel Cron

# ── Web Push (VAPID) — generate with `npx web-push generate-vapid-keys` ──────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kilorin.app

# ── Integrations ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                                     # AI Avatar recipe generation (optional in V1)
COINGECKO_API_KEY=                                     # optional; public API works without it (rate-limited)

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
